{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "gastroconecta2026.com.br"
        }
      ],
      "destination": "/gastroconecta2026/index.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.gastroconecta2026.com.br"
        }
      ],
      "destination": "/gastroconecta2026/index.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "tgirecife.com.br"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.tgirecife.com.br"
        }
      ],
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
