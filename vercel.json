{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path((?!tgi).*)*",
      "has": [
        {
          "type": "host",
          "value": "tgirecife.com.br"
        }
      ],
      "destination": "/tgi/:path*"
    },
    {
      "source": "/:path((?!tgi).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.tgirecife.com.br"
        }
      ],
      "destination": "/tgi/:path*"
    },
    {
      "source": "/:path((?!gastroconecta2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "gastroconecta2026.com.br"
        }
      ],
      "destination": "/gastroconecta2026/:path*"
    },
    {
      "source": "/:path((?!gastroconecta2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.gastroconecta2026.com.br"
        }
      ],
      "destination": "/gastroconecta2026/:path*"
    },
    {
      "source": "/:path((?!endogineco2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "congressoendoginecorecife.com.br"
        }
      ],
      "destination": "/endogineco2026/:path*"
    },
    {
      "source": "/:path((?!endogineco2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.congressoendoginecorecife.com.br"
        }
      ],
      "destination": "/endogineco2026/:path*"
    },
    {
      "source": "/:path((?!oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "oncodermarecife.com.br"
        }
      ],
      "destination": "/oncoderma2026/:path*"
    },
    {
      "source": "/:path((?!oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.oncodermarecife.com.br"
        }
      ],
      "destination": "/oncoderma2026/:path*"
    },
    {
      "source": "/:path((?!oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "oncodermarecife2026.com.br"
        }
      ],
      "destination": "/oncoderma2026/:path*"
    },
    {
      "source": "/:path((?!oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "www.oncodermarecife2026.com.br"
        }
      ],
      "destination": "/oncoderma2026/:path*"
    },
    {
      "source": "/:path((?!portfolio|tgi|gastroconecta2026|endogineco2026|oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "lukaplan.vercel.app"
        }
      ],
      "destination": "/portfolio/:path*"
    },
    {
      "source": "/:path((?!portfolio|tgi|gastroconecta2026|endogineco2026|oncoderma2026).*)*",
      "has": [
        {
          "type": "host",
          "value": "(.*)\\.vercel\\.app"
        }
      ],
      "destination": "/portfolio/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
